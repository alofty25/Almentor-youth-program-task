# =============================================================================
#  .env.docker.example — Docker environment configuration template
#
#  How to use:
#    cp .env.docker.example .env.docker
#    # Edit .env.docker with your values, then:
#    docker compose up --build
#
#  NOTE: .env.docker is gitignored. Never commit real credentials.
# =============================================================================

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------

# REQUIRED — Generate a unique secret key before running in production.
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-secret-key

# Set to False in production!
DEBUG=True

# Comma-separated list of hostnames the app responds to.
# In development: leave as shown. In production: add your domain, e.g. api.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ---------------------------------------------------------------------------
# PostgreSQL Database
# Matched to the 'db' service in docker-compose.yml.
# DB_HOST must remain 'db' (the Docker service name) when using Docker.
# ---------------------------------------------------------------------------
DB_NAME=task_management_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# ---------------------------------------------------------------------------
# Seeding (optional)
# Set to 'true' to automatically seed the DB with realistic data on first boot.
# Set to 'false' to skip seeding (safe for subsequent restarts).
# ---------------------------------------------------------------------------
SEED_DB=false
