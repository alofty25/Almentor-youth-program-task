# =============================================================================
#  .env.example — Non-Docker local development configuration template
#
#  How to use:
#    cp .env.example .env
#    # Fill in your local PostgreSQL credentials, then:
#    uv run python manage.py migrate
#    uv run python manage.py runserver
#
#  NOTE: .env is gitignored. Never commit real credentials.
# =============================================================================

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------

# REQUIRED — Generate a unique secret key before running.
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-secret-key

# Set to False in production!
DEBUG=True

# Comma-separated list of valid hostnames.
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# PostgreSQL — Local installation (NOT Docker)
# Point this at your local Postgres instance.
# ---------------------------------------------------------------------------
DB_NAME=task_management_db
DB_USER=postgres
DB_PASSWORD=your_local_postgres_password
DB_HOST=localhost
DB_PORT=5432
